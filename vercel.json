{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/app.py": {
      "excludeFiles": "{tests/**,__tests__/**,**/*.test.py,**/test_*.py,.pytest_cache/**,__pycache__/**,**/__pycache__/**,data/uploads/**,*.ipynb,**/*.ipynb}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/app"
    }
  ],
  "cleanUrls": true
}
